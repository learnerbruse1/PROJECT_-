# ==============================================================================
# 洪山区人口分布热力与公共设施叠加分析系统 — Git 忽略规则
#
# 约定：依赖、构建产物、密钥、原始大数据不入库；
#       成果数据 data/processed/ 与依赖锁文件 (package-lock.json) 保留跟踪。
# ==============================================================================

# ── Python（后端）────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 虚拟环境
.venv/
venv/
env/
ENV/

# ── Node / 前端 ──────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
.vite/
*.local
.eslintcache
coverage/

# 包管理器调试日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── 环境变量 / 密钥 ──────────────────────────────────────────────
# 真实 .env（含天地图密钥等）不入库；仅提交 .env.example 模板。
.env
.env.*
!.env.example

# ── 数据 ─────────────────────────────────────────────────────────
# data/raw/  : 原始源数据（栅格 / Shapefile，体积大、可由 scripts/ 再生）→ 忽略
# data/processed/ : 系统运行依赖的成果 GeoJSON → 保留跟踪（不在此忽略）
data/raw/

# ── 日志 / 临时产物 ──────────────────────────────────────────────
*.log
*.tmp
*.bak

# ── Office 临时锁文件 ────────────────────────────────────────────
~$*.docx
~$*.xlsx
~$*.pptx

# ── 编辑器 / IDE ─────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*~

# ── 操作系统 ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── AI 助手本地配置 ──────────────────────────────────────────────
.claude/
