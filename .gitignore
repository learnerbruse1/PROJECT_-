# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ── Node / 前端 ──
node_modules/
dist/
frontend/dist/
.vite/

# ── 环境变量（含密钥，不提交；改为提交 *.env.example 模板）──
.env
.env.local
frontend/.env

# ── 原始/中间数据（大文件，可由 scripts/栅格重采样.py 再生）──
# data/processed/ 为系统运行所依赖的成果数据，需要保留跟踪。
data/raw/

# ── 日志 / 临时 / 验证产物 ──
*.log
_verify_*.png
_*.png

# ── Office 临时锁文件 ──
~$*.docx
~$*.xlsx

# ── 编辑器 / 系统 ──
.DS_Store
Thumbs.db
.idea/
.vscode/

# —— AI配置文件 ──
.claude