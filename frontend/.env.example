# 前端环境变量模板 —— 复制为 .env 后按需填写（.env 不提交到仓库）
#   cp .env.example .env

# 天地图开发者密钥（https://console.tianditu.gov.cn/ 申请）
# 留空时地图会自动回退到 OpenStreetMap / 高德底图，系统仍可正常使用。
VITE_TIANDITU_KEY=27533d3d40c76df499357d7d30cf54dc

# 后端 API 基址（开发期经 Vite 代理转发到后端，通常无需修改）
VITE_API_BASE_URL=/api/v1

# 可选：直连远程后端（设置后开发期 /api 代理目标改为此地址）
# VITE_BACKEND_ORIGIN=http://127.0.0.1:8000
